---
import DarkModeIcon from './icons/DarkModeIcon.astro';
import LightModeIcon from './icons/LightModeIcon.astro';

const pathname = Astro.url.pathname;
const isHome = pathname === '/';
const isBlog = pathname.startsWith('/blog');
---

<header class="sticky top-0 z-30 border-b border-border bg-card/90 backdrop-blur">
	<nav class="mx-auto flex w-full max-w-6xl items-center justify-between px-5 py-4 md:px-8">
		<a href="/" class="font-[Fraunces] text-xl tracking-tight">mtstnt</a>
		<div class="flex items-center gap-4 text-sm uppercase tracking-[0.2em] text-muted-foreground">
			<a href="/" class={`pb-1 transition hover:text-foreground ${isHome ? 'border-b border-foreground text-foreground' : ''}`}>Home</a>
			<a href="/blog" class={`pb-1 transition hover:text-foreground ${isBlog ? 'border-b border-foreground text-foreground' : ''}`}>Blog</a>
			<button
				id="theme-toggle"
				type="button"
				class="rounded-full border border-border px-3 py-1.5 text-[10px] font-semibold tracking-[0.2em]"
			>
				<span id="dark-mode-icon" class="hidden"><DarkModeIcon width={16} height={16} /></span>
				<span id="light-mode-icon" class="hidden"><LightModeIcon width={16} height={16} /></span>
			</button>
		</div>
	</nav>
</header>
