---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import Layout from '../../layouts/Layout.astro';
import { SITE_METADATA } from '../../settings';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const hasPosts = posts.length > 0;
const hasValidImage = (image: unknown): image is import('astro').ImageMetadata =>
	typeof image === 'object' && image !== null && 'src' in image;
---

<Layout
	title={SITE_METADATA.title}
	description={SITE_METADATA.description}
	mainClass="relative mx-auto w-full max-w-6xl px-5 pb-16 pt-12 md:px-8 md:pt-16"
	backgroundClass="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(0,0,0,0.08),_transparent_52%)] dark:bg-[radial-gradient(circle_at_top_left,_rgba(255,255,255,0.07),_transparent_52%)]"
>
	<section class="mb-12 space-y-4">
		<p class="text-xs uppercase tracking-[0.35em] text-muted-foreground">Journal archive</p>
		<h1 class="max-w-3xl font-[Fraunces] text-5xl leading-[0.95] md:text-6xl">
			Technical essays, build logs, and experiments.
		</h1>
		<p class="max-w-2xl text-base leading-relaxed text-muted-foreground">
			A running catalog of software notes, from architecture sketches to post-mortems.
		</p>
	</section>

	<section class="grid gap-6 md:grid-cols-2">
		{hasPosts ? (
			posts.map((post, index) => (
				<article class={`rounded-3xl border border-border bg-card p-5 transition hover:-translate-y-0.5 hover:border-muted-foreground md:p-6 ${index === 0 ? 'md:col-span-2 md:grid md:grid-cols-[0.9fr_1.1fr] md:items-center md:gap-8' : ''}`}>
					<a href={`/blog/${post.id}/`} class="block">
						{hasValidImage(post.data.heroImage) && (
							<div class={`overflow-hidden rounded-2xl border border-border ${index === 0 ? 'mb-0' : 'mb-4'}`}>
								<Image
									src={post.data.heroImage}
									width={index === 0 ? 920 : 720}
									height={index === 0 ? 500 : 360}
									alt={post.data.title}
									class="h-full w-full object-cover"
								/>
							</div>
						)}
						<div class={index === 0 ? 'mt-5 md:mt-0' : ''}>
							<p class="text-xs uppercase tracking-[0.25em] text-muted-foreground">
								<FormattedDate date={post.data.pubDate} />
							</p>
							<h2 class={`mt-3 font-[Fraunces] leading-tight ${index === 0 ? 'text-4xl' : 'text-3xl'}`}>
								{post.data.title}
							</h2>
							<p class="mt-3 text-sm leading-relaxed text-muted-foreground">{post.data.description}</p>
						</div>
					</a>
				</article>
			))
		) : (
			<article class="rounded-3xl border border-dashed border-border bg-muted p-8 md:col-span-2 md:p-10">
				<p class="text-xs uppercase tracking-[0.28em] text-muted-foreground">No articles yet</p>
				<h2 class="mt-3 font-[Fraunces] text-3xl leading-tight">The writing archive is empty.</h2>
				<p class="mt-3 max-w-2xl text-sm leading-relaxed text-muted-foreground">
					Publish your first markdown article in <code>src/content/blog</code> and it will appear here.
				</p>
			</article>
		)}
	</section>
</Layout>
