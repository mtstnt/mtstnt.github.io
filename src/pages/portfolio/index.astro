---
import { Image } from 'astro:assets';
import { getCollection } from 'astro:content';
import defaultCoverImage from '../../assets/blog-placeholder-4.jpg';
import Layout from '../../layouts/Layout.astro';
import { SITE_METADATA } from '../../settings';

const portfolioItems = (await getCollection('portfolio')).sort((a, b) => {
	const featuredOrder = Number(b.data.featured) - Number(a.data.featured);
	if (featuredOrder !== 0) return featuredOrder;
	return (b.data.pubDate?.valueOf() ?? 0) - (a.data.pubDate?.valueOf() ?? 0);
});

const hasPortfolioItems = portfolioItems.length > 0;
const getCoverImage = (image: unknown) =>
	typeof image === 'object' && image !== null && 'src' in image ? image : defaultCoverImage;
---

<Layout
	title={`Portfolio | ${SITE_METADATA.title}`}
	description={SITE_METADATA.description}
	mainClass="relative mx-auto w-full max-w-6xl px-5 pb-16 pt-12 md:px-8 md:pt-16"
	backgroundClass="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_left,_rgba(0,0,0,0.08),_transparent_52%)] dark:bg-[radial-gradient(circle_at_top_left,_rgba(255,255,255,0.07),_transparent_52%)]"
>
	<section class="mb-10 space-y-4">
		<p class="text-xs uppercase tracking-[0.35em] text-muted-foreground">Portfolio</p>
		<h1 class="max-w-3xl font-[Fraunces] text-5xl leading-[0.95] md:text-6xl">Selected software projects.</h1>
		<p class="max-w-2xl text-base leading-relaxed text-muted-foreground">
			A markdown-driven archive of things I designed and shipped.
		</p>
	</section>

	<section class="grid gap-6 md:grid-cols-2">
		{hasPortfolioItems ? (
			portfolioItems.map((item) => (
				<article class="rounded-3xl border border-border bg-card p-5 transition hover:-translate-y-0.5 hover:border-muted-foreground md:p-6">
					<a href={`/portfolio/${item.id}/`} class="block">
						<div class="mb-4 overflow-hidden rounded-2xl border border-border bg-muted">
						<Image
							src={getCoverImage(item.data.coverImage)}
							width={900}
								height={500}
								alt={item.data.title}
								class="h-full w-full object-cover"
							/>
						</div>
						<h2 class="font-[Fraunces] text-3xl leading-tight">{item.data.title}</h2>
						<p class="mt-3 text-sm leading-relaxed text-muted-foreground">{item.data.summary}</p>
						{item.data.stack.length > 0 && (
							<ul class="mt-4 flex flex-wrap gap-2 text-xs uppercase tracking-[0.18em] text-muted-foreground">
								{item.data.stack.map((tech) => (
									<li class="rounded-full border border-border px-2.5 py-1">{tech}</li>
								))}
							</ul>
						)}
					</a>
				</article>
			))
		) : (
			<article class="rounded-3xl border border-dashed border-border bg-muted p-8 md:col-span-2 md:p-10">
				<p class="text-xs uppercase tracking-[0.28em] text-muted-foreground">No portfolio entries yet</p>
				<h2 class="mt-3 font-[Fraunces] text-3xl leading-tight">Your project showcase is empty.</h2>
				<p class="mt-3 max-w-2xl text-sm leading-relaxed text-muted-foreground">
					Add a markdown file under <code>src/content/portfolio</code> to publish a new case study.
				</p>
			</article>
		)}
	</section>
</Layout>
